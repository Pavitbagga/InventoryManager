datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  color     String    @default("#4CAF50")
  position  Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id         Int        @id @default(autoincrement())
  name       String
  price      Float
  color      String     @default("#4CAF50")
  pluCode    String?    @unique
  stock      Int        @default(0)
  categoryId Int
  category   Category   @relation(fields: [categoryId], references: [id])
  billItems  BillItem[]
  createdAt  DateTime   @default(now())
}

model Clerk {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  pin       String
  email     String?
  phone     String?
  role      String   @default("clerk")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Bill {
  id          Int        @id @default(autoincrement())
  billNumber  String     @unique
  clerkId     String     @default("CLERK 001")
  tableNumber String?
  subtotal    Float
  discount    Float      @default(0)
  total       Float
  paymentMode String     @default("CASH")
  status      String     @default("PAID")
  items       BillItem[]
  createdAt   DateTime   @default(now())
}

model BillItem {
  id        Int     @id @default(autoincrement())
  billId    Int
  bill      Bill    @relation(fields: [billId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int
  total     Float
}

model BillConfig {
  id              Int     @id @default(autoincrement())
  shopName        String  @default("MY SHOP")
  shopAddress     String  @default("")
  shopPhone       String  @default("")
  shopGST         String  @default("")
  footerMessage   String  @default("Thank you! Visit again.")
  showLogo        Boolean @default(false)
  showGST         Boolean @default(true)
  showAddress     Boolean @default(true)
  showPhone       Boolean @default(true)
  showClerk       Boolean @default(true)
  showTable       Boolean @default(false)
  showItemRate    Boolean @default(true)
  showDiscount    Boolean @default(true)
  paperWidth      Int     @default(80)
  currency        String  @default("Rs.")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
